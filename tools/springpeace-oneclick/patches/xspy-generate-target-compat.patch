+def locate_markers(data: bytes, token_table_off: int) -> tuple[int, tuple[int, ...]]:
+    # Upstream kernels usually place kallsyms_markers immediately before
+    # kallsyms_token_table with only tiny zero alignment padding. Some vendor
+    # 6.1/6.12 Android builds keep an extra generated table/alignment blob in
+    # this gap, so fall back to a wider marker scan before giving up.
+    strict = collect_marker_candidates(
+        data, token_table_off, max_gap=32, require_zero_gap=True
+    )
+    if len(strict) == 1:
+        return next(iter(strict.items()))
+    loose = collect_marker_candidates(
+        data, token_table_off, max_gap=4 * 1024 * 1024, require_zero_gap=False
+    )
+    if len(loose) == 1:
+        return next(iter(loose.items()))
+    shown = loose if loose else strict
+    fail(
+        "kallsyms markers ?????: "
+        + repr([(hex(k), len(v)) for k, v in shown.items()])
+        + f"; strict={len(strict)} loose={len(loose)}"
+    )
 
 
